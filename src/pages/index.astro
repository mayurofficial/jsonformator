---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonEditor from '../components/islands/JsonEditor';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="JSON Formatter & Viewer — Instant, Privacy-First Online Beautifier"
  description="Free online JSON Formatter, Viewer, and Syntax Repair tool. Format, validate, and beautify JSON with 100% in-browser Web Worker privacy, zero latency, and zero CLS."
  hideFooter={true}
>
  <!-- IDE Master Layout: Fixed Left Sidebar (145px) + Right Main Content (Cards + Footer) -->
  <div style="width: 100%; display: flex; flex-direction: column;">
    <JsonEditor client:idle />
    
    <!-- Footer Positioned in Right Main Section Aligned with 1rem Card Margin -->
    <div style="margin-left: 145px; margin-top: 1rem; border-top: 1px solid var(--border-subtle); padding: 0 1rem;">
      <Footer />
    </div>
  </div>
</BaseLayout>

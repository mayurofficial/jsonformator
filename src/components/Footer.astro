---
---
<footer style="background: var(--bg-secondary); border-top: 1px solid var(--border-subtle); margin-top: 4rem; padding: 3rem 0 2rem 0;">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; margin-bottom: 2.5rem;">
      <!-- Col 1: Brand & Privacy -->
      <div>
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
          <span style="font-weight: 800; font-size: 1.1rem;">JSON<span style="color: var(--accent-emerald);">Formator</span></span>
        </div>
        <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 1rem;">
          High-performance, privacy-first JSON developer toolkit. Zero-JS baseline static shell with client-side Web Worker execution.
        </p>
        <p style="font-size: 0.75rem; color: var(--accent-emerald); display: flex; align-items: center; gap: 0.4rem;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          No payloads leave your web browser.
        </p>
      </div>

      <!-- Col 2: Core Tools -->
      <div>
        <h4 style="font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem;">Developer Tools</h4>
        <ul style="list-style: none; font-size: 0.85rem; display: flex; flex-direction: column; gap: 0.4rem;">
          <li><a href="/" style="color: var(--text-secondary); text-decoration: none;">JSON Formatter & Viewer</a></li>
          <li><a href="/compare" style="color: var(--text-secondary); text-decoration: none;">JSON Compare & Visual Diff</a></li>
          <li><a href="/validator" style="color: var(--text-secondary); text-decoration: none;">JSON Validator & Syntax Repair</a></li>
          <li><a href="/minify" style="color: var(--text-secondary); text-decoration: none;">JSON Minifier & Compressor</a></li>
          <li><a href="/tree" style="color: var(--text-secondary); text-decoration: none;">JSON Tree Explorer</a></li>
        </ul>
      </div>

      <!-- Col 3: Converters -->
      <div>
        <h4 style="font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem;">Data Converters</h4>
        <ul style="list-style: none; font-size: 0.85rem; display: flex; flex-direction: column; gap: 0.4rem;">
          <li><a href="/json-to-csv" style="color: var(--text-secondary); text-decoration: none;">JSON to CSV Converter</a></li>
          <li><a href="/json-to-yaml" style="color: var(--text-secondary); text-decoration: none;">JSON to YAML Converter</a></li>
          <li><a href="/json-to-typescript" style="color: var(--text-secondary); text-decoration: none;">JSON to TypeScript Interfaces</a></li>
          <li><a href="/json-to-go" style="color: var(--text-secondary); text-decoration: none;">JSON to Go Struct Generator</a></li>
        </ul>
      </div>

      <!-- Col 4: Performance & Compliance -->
      <div>
        <h4 style="font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem;">SEO & Performance</h4>
        <p style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.5;">
          Built with Astro Islands SSG, Cloudflare CDN Edge, 100/100 Core Web Vitals, 0 CLS, and WCAG 2.1 AA Accessibility compliance.
        </p>
      </div>
    </div>

    <div style="border-top: 1px solid var(--border-subtle); padding-top: 1.5rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; font-size: 0.8rem; color: var(--text-muted);">
      <p>&copy; {new Date().getFullYear()} jsonformator.com — All rights reserved.</p>
      <p style="font-family: var(--font-mono);">Privacy-First Local Storage Engine</p>
    </div>
  </div>
</footer>

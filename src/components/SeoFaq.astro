---
export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  faqs: FaqItem[];
  title?: string;
}

const { faqs, title = "Frequently Asked Questions" } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<!-- Pre-rendered FAQ Schema.org JSON-LD -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

<section style="margin: 3.5rem 0;" aria-labelledby="faq-heading">
  <h2 id="faq-heading" style="font-size: 1.5rem; font-weight: 800; color: var(--text-primary); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent-emerald)" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    {title}
  </h2>

  <div style="display: flex; flex-direction: column; gap: 1rem;">
    {faqs.map((faq) => (
      <details style="background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 0.5rem; padding: 1rem 1.25rem; transition: border-color 0.2s ease;">
        <summary style="font-size: 1rem; font-weight: 700; color: var(--text-primary); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;">
          <span>{faq.question}</span>
          <span style="color: var(--accent-emerald); font-size: 1.2rem; font-weight: 400;">+</span>
        </summary>
        <p style="margin-top: 0.75rem; font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; border-top: 1px solid var(--border-subtle); padding-top: 0.75rem;">
          {faq.answer}
        </p>
      </details>
    ))}
  </div>
</section>
